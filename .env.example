# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI APIs
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# WhatsApp (Meta Cloud API + Dualhook)
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_APP_SECRET=
DUALHOOK_API_KEY=
DUALHOOK_SIGNING_SECRET=         # optional: Dualhook tech-provider app secret (ask their support)
DUALHOOK_API_BASE=               # optional: Dualhook REST base (default https://api.dualhook.com/v1)
WHATSAPP_WEBHOOK_URL_TOKEN=      # random token in the webhook URL (?t=...) — auth fallback under Coexistence

# WhatsApp Embedded Signup (Coexistence) — onboarding "Connect WhatsApp" step.
# These are Dualhook's tech-provider Meta app credentials (public, safe in the browser).
# Ask Dualhook support for the App ID + the Embedded-Signup Configuration ID.
NEXT_PUBLIC_FB_APP_ID=           # Dualhook Meta App ID (drives the Facebook JS SDK)
NEXT_PUBLIC_FB_CONFIG_ID=        # Dualhook Embedded-Signup configuration_id (Coexistence)
NEXT_PUBLIC_FB_GRAPH_VERSION=    # optional: Graph API version for FB.init (default v21.0)

# n8n orchestration + internal callbacks
N8N_WEBHOOK_URL=                 # n8n master-handler production webhook
N8N_API=                         # n8n REST API key (for workflow management, not message flow)
INTERNAL_API_KEY=                # shared secret: Next.js ↔ n8n callbacks (x-internal-api-key)
CRON_SECRET=                     # Vercel Cron bearer token — guards /api/cron/* (savings snapshot)

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Monitoring
SENTRY_DSN=                      # server-side Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=          # client-side Sentry DSN (can be the same value as SENTRY_DSN)
SENTRY_DASHBOARD_URL=            # optional: platform-admin "Open Sentry" link target (default https://sentry.io)
NEXT_PUBLIC_POSTHOG_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
